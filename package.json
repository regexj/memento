{
  "name": "memento",
  "version": "1.0.0",
  "description": "A locally-running scheduled agent that builds an automated work diary",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "all-check": "npm run typecheck && npm run format:check && npm run lint && npm run test:coverage",
    "collect": "node src/collect.ts",
    "format:check": "prettier --check .",
    "format:write": "prettier --write .",
    "lint": "eslint . --ext .ts,.js",
    "list-tools": "node src/list-tools.ts",
    "memento": "node src/cli.ts run",
    "prepare": "lefthook install",
    "review": "node src/cli.ts review",
    "test": "vitest run .spec.ts",
    "test:coverage": "vitest run .spec.ts --coverage",
    "test:name": "vitest run --reporter=verbose --hideSkippedTests",
    "test:watch": "vitest watch .spec.ts",
    "typecheck": "tsc --noEmit --diagnostics"
  },
  "keywords": [
    "memento",
    "work-diary",
    "self-review"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.74",
    "@ai-sdk/google": "^3.0.67",
    "@ai-sdk/mistral": "^3.0.34",
    "@ai-sdk/openai": "^3.0.60",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ai": "^6.0.175",
    "node-notifier": "^10.0.1",
    "ollama-ai-provider-v2": "^3.5.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.0",
    "@commitlint/config-conventional": "^21.0.0",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/node": "^24.0.0",
    "@types/node-notifier": "^8.0.5",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "lefthook": "^2.1.6",
    "prettier": "^3.8.3",
    "typescript-eslint": "^8.59.2",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
