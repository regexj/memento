{
  "name": "memento",
  "version": "1.0.0",
  "description": "A locally-running scheduled agent that builds an automated work diary",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "memento": "node src/cli.ts run",
    "review": "node src/cli.ts review",
    "test": "vitest run .spec.ts",
    "test:coverage": "vitest run .spec.ts --coverage",
    "test:name": "vitest run --reporter=verbose --hideSkippedTests",
    "test:watch": "vitest watch .spec.ts"
  },
  "keywords": [
    "memento",
    "work-diary",
    "self-review"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.74",
    "@ai-sdk/google": "^3.0.67",
    "@ai-sdk/mistral": "^3.0.34",
    "@ai-sdk/openai": "^3.0.60",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ai": "^6.0.175",
    "dotenv": "^17.4.2",
    "node-notifier": "^10.0.1",
    "ollama-ai-provider-v2": "^3.5.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/node-notifier": "^8.0.5",
    "@vitest/coverage-v8": "^4.1.5",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
