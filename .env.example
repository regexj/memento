# =============================================================================
# Memento Configuration
# =============================================================================
# Copy this file to .env and fill in your values.

# =============================================================================
# LLM Provider Settings (REQUIRED)
# =============================================================================

# The LLM provider to use for summarization and review generation.
# Supported values: anthropic, openai, google, mistral, ollama
LLM_PROVIDER=anthropic

# The model identifier for the chosen provider.
# Examples:
#   Anthropic: claude-sonnet-4-20250514
#   OpenAI:    gpt-4o
#   Google:    gemini-2.0-flash
#   Mistral:   mistral-large-latest
#   Ollama:    llama3.2
LLM_MODEL=claude-sonnet-4-20250514

# API key for the chosen provider.
# Required for cloud providers (anthropic, openai, google, mistral).
# Optional for local providers (ollama).
LLM_API_KEY=sk-your-api-key-here

# =============================================================================
# Data Source Settings
# =============================================================================

# Comma-separated list of enabled data sources.
# Default: github,jira,confluence
# MEMENTO_SOURCES=github,jira,confluence

# --- GitHub ---
# Required if github is in MEMENTO_SOURCES.
GITHUB_USERNAME=your-github-username

# --- Jira ---
# Required if jira is in MEMENTO_SOURCES.
JIRA_USERNAME=your-jira-username
JIRA_BASE_URL=https://your-org.atlassian.net

# --- Confluence ---
# Required if confluence is in MEMENTO_SOURCES.
CONFLUENCE_BASE_URL=https://your-org.atlassian.net/wiki

# =============================================================================
# Review Cycle Settings
# =============================================================================

# The month (1-12) when your annual review cycle starts.
# Default: 1 (January)
# Example: 5 means the cycle runs May to April.
# REVIEW_CYCLE_MONTH=1

# =============================================================================
# Optional Settings
# =============================================================================

# Path to the diary output directory.
# Default: ./diary
# DIARY_DIR=./diary

# Path to the log file.
# Default: ./memento.log
# LOG_FILE=./memento.log
